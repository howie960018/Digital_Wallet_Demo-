spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/digital_wallet
    username: your_username
    password: your_password
  jpa:
    hibernate:
      ddl-auto: create
    show-sql: true
    open-in-view: false
    properties:
      hibernate:
        format_sql: true

jwt:
  secret: your_256bit_hex_secret_key_here_at_least_32_chars
  expiration: 86400000  # 24 hours (milliseconds)
